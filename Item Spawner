local function InitSword()
    Engine:Log("Injecting Asset...")
    
    local tool
    local success, _ = pcall(function()
        tool = game:GetObjects("rbxassetid://" .. pedangID)[1]
    end)
    
    if not success or not tool then
        Engine:Log("Using Custom Poly-Tool")
        tool = Instance.new("Tool")
        local h = Instance.new("Part", tool)
        h.Name = "Handle"
        h.Size = Vector3.new(0.8, 5, 0.8)
        h.Transparency = 0.2
        h.Material = Enum.Material.Neon
        h.Color = Color3.fromRGB(200, 0, 255)
    end
    
    tool.Name = "FE_GOD_SWORD"
    tool.Parent = player.Backpack
    
    local handle = tool:FindFirstChild("Handle")
    local lastPassiveHit = 0

    -- [PASSIVE DAMAGE: 5/sec]
    handle.Touched:Connect(function(hit)
        if tick() - lastPassiveHit < 1 then return end
        local char = hit.Parent
        if char and char:FindFirstChild("Humanoid") and char.Name ~= player.Name then
            lastPassiveHit = tick()
            Engine:ApplyDamage(char, 5)
            Engine:Log("Passive Hit (5)")
        end
    end)

    -- [ACTIVE DAMAGE: SWING & LUNGE]
    tool.Activated:Connect(function()
        local t = mouse.Target
        if t and t.Parent and t.Parent:FindFirstChild("Humanoid") then
            local enemy = t.Parent
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            
            if root then
                local distance = (root.Position - t.Position).Magnitude
                
                -- Lunge Detection (Dist > 10 or Move Speed)
                if distance > 10 or player.Character.Humanoid.MoveDirection.Magnitude > 0.2 then
                    Engine:ApplyDamage(enemy, 30)
                    Engine:Log("Lunge Strike (30)")
                else
                    Engine:ApplyDamage(enemy, 20)
                    Engine:Log("Swing Strike (20)")
                end
            end
        end
    end)
    
    Engine:Log("Sword Ready")
end

