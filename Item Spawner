function Engine:FetchRemotes()
    local found = {}
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local name = v.Name:lower()
            for _, m in pairs(self.Methods) do
                if name:find(m:lower()) then
                    table.insert(found, v)
                end
            end
        end
    end
    self.RemoteCache = found
    return found
end

function Engine:ApplyDamage(target, val)
    if not target or not target:FindFirstChild("Humanoid") then return end
    local hum = target.Humanoid
    
    -- Multi-Method Dispatcher
    task.spawn(function()
        for _, remote in pairs(self.RemoteCache) do
            pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:FireServer(hum, val)
                    remote:FireServer(target, val)
                    remote:FireServer(hum, val, "Head", math.random(1,10))
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer(hum, val)
                end
            end)
        end
    end)
    
    -- Client-Side Override
    pcall(function()
        hum.Health = hum.Health - val
    end)
end

